# Copy this file to .env and fill in your Gmail credentials.
#
# GMAIL_USER         → Gmail address used as the sender
#                      e.g. youraccount@gmail.com
#
# GMAIL_APP_PASSWORD → Gmail App Password (NOT your normal account password).
#                      Generate one at: https://myaccount.google.com/apppasswords
#                      (Requires 2-Step Verification to be enabled on the sender account.)
#
# MAIL_TO            → Recipient email address for form submissions.
#                      Required. Set to the address that should receive submissions.
#
# PORT (optional)    → Port the local Express server listens on. Defaults to 3000.

GMAIL_USER=youraccount@gmail.com
GMAIL_APP_PASSWORD=your-gmail-app-password
MAIL_TO=massimoperfetti4@gmail.com
PORT=3000
