# Copy this file to .env and fill in your Gmail credentials.
#
# GMAIL_USER        → The Gmail address used as the sender (e.g. youraccount@gmail.com)
# GMAIL_APP_PASSWORD → A Gmail App Password (NOT your normal account password).
#                      Generate one at: https://myaccount.google.com/apppasswords
#                      (Requires 2-Step Verification to be enabled on the account.)
#
# PORT (optional) → The port the server will listen on. Defaults to 3000.

GMAIL_USER=youraccount@gmail.com
GMAIL_APP_PASSWORD=your_app_password_here
PORT=3000
